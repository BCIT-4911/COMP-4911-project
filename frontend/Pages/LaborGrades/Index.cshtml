@page
@model frontend.Pages.LaborGrades.IndexModel
@using frontend.model

@{
    ViewData["Title"] = "Labor Grades";
    var laborGrades = ViewData["LaborGrades"] as List<LaborGrade> ?? new List<LaborGrade>();
}

@section Head {
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
}

<div class="labor-grades-page">
<div class="labor-grades-canvas">
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="labor-grades-header">
        <div class="labor-grades-header-row">
            <div>
                <h1 class="labor-grades-page-title">Labor Grades</h1>
                <p class="labor-grades-page-subtitle mb-0 mt-1">Manage labor grades and charge rates</p>
            </div>
            <a asp-page="/LaborGrades/Create" class="labor-grades-btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" height="24" viewBox="0 -960 960 960" width="24" aria-hidden="true">
                    <path d="M440-440H200v-80h240v-240h80v240h240v80H520v240h-80v-240Z"/>
                </svg>
                Add Labor Grade
            </a>
        </div>
    </div>

    <div class="labor-grades-toolbar">
        <div class="input-group flex-grow-1 labor-grades-search-group">
            <span class="input-group-text">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                </svg>
            </span>
            <input type="text" id="laborGradeSearchInput" class="form-control shadow-none"
                   placeholder="Search by grade code or charge rate..."
                   oninput="filterLaborGrades()">
        </div>
    </div>

    <div class="labor-grades-table-shell">
        <table class="table table-hover mb-0 labor-grades-table" id="laborGradeTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Grade Code</th>
                    <th>Charge Rate</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var lg in laborGrades)
                {
                    <tr class="labor-grade-row"
                        data-code="@lg.gradeCode"
                        data-rate="@lg.chargeRate">
                        <td class="labor-grades-id-cell">
                            @lg.laborGradeId
                        </td>
                        <td>
                            <span class="badge rounded-pill labor-grades-code-badge">
                                @lg.gradeCode
                            </span>
                        </td>
                        <td>
                            <span class="labor-grades-rate">
                                $@lg.chargeRate.ToString("F2")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-page="/LaborGrades/Create" asp-route-id="@lg.laborGradeId"
                               class="labor-grades-action-btn" title="Edit">
                               <svg xmlns="http://www.w3.org/2000/svg" height="24" viewBox="0 -960 960 960" width="24" aria-hidden="true"><path d="M200-200h57l391-391-57-57-391 391v57Zm-80 80v-170l528-527q12-11 26.5-17t30.5-6q16 0 31 6t26 18l55 56q12 11 17.5 26t5.5 30q0 16-5.5 30.5T817-647L290-120H120Zm640-584-56-56 56 56Zm-141 85-28-29 57 57-29-28Z"/></svg>
                            </a>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@lg.laborGradeId"
                                  class="d-inline"
                                  onsubmit="return confirm('Are you sure you want to delete this labor grade?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="labor-grades-action-btn labor-grades-action-btn--danger" title="Delete">
                                    <svg xmlns="http://www.w3.org/2000/svg" height="24" viewBox="0 -960 960 960" width="24" aria-hidden="true"><path d="M280-120q-33 0-56.5-23.5T200-200v-520h-40v-80h200v-40h240v40h200v80h-40v520q0 33-23.5 56.5T680-120H280Zm400-600H280v520h400v-520ZM360-280h80v-360h-80v360Zm160 0h80v-360h-80v360ZM280-720v520-520Z"/></svg>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <small class="labor-grades-footer-note">Showing @laborGrades.Count labor grade(s)</small>
    </div>
</div>
</div>

@section Scripts {
    <script>
        function filterLaborGrades() {
            const searchValue = document.getElementById('laborGradeSearchInput').value.toLowerCase();
            const rows = document.querySelectorAll('.labor-grade-row');

            rows.forEach(row => {
                const code = (row.getAttribute('data-code') || '').toLowerCase();
                const rate = (row.getAttribute('data-rate') || '').toLowerCase();

                const matchesSearch = code.includes(searchValue) || rate.includes(searchValue);
                row.style.display = matchesSearch ? '' : 'none';
            });
        }
    </script>
}
