@page
@model frontend.Pages.Timesheets.ReviewModel
@{
    ViewData["Title"] = "Timesheet Details";
}

@section Head {
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
}

<div class="timesheet-page">
    <div class="timesheet-canvas">
        <div class="timesheet-header d-flex align-items-end justify-content-between flex-wrap gap-3">
            <div>
                <h1 class="timesheet-page-title">Timesheet Details</h1>
                <p class="timesheet-page-subtitle">View your submitted timesheet, and edit/resubmit if it was returned.</p>
            </div>
            <a href="/Timesheets/Index" class="btn btn-timesheet-add">Back to Timesheets</a>
        </div>

        <div id="alertArea"></div>
        <div id="loadingArea" class="info-card mb-4">Loading timesheet...</div>

        <div id="contentArea" style="display:none;">
            <div class="info-card mb-4">
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="info-label">Timesheet ID</div>
                        <div class="info-value" id="tsIdDisplay"></div>
                    </div>
                    <div class="col-md-3">
                        <div class="info-label">Employee</div>
                        <div class="info-value" id="empDisplay"></div>
                    </div>
                    <div class="col-md-3">
                        <div class="info-label">Approver</div>
                        <div class="info-value" id="approverDisplay"></div>
                    </div>
                    <div class="col-md-3">
                        <div class="info-label">Status</div>
                        <div class="info-value" id="statusDisplay"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-label">Week Ending</div>
                        <input type="date" id="weekEndingInput" class="info-value timesheet-week-input border-0 p-0 bg-transparent w-100" />
                    </div>
                </div>
            </div>

            <div id="returnCommentCard" class="info-card mb-4" style="display:none;">
                <div class="info-label">Returned Comment</div>
                <div class="info-value" id="returnCommentDisplay"></div>
            </div>

            <div class="timesheet-container">
                <div class="table-responsive">
                    <table class="table table-ts align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="th-col-wp">Work Package</th>
                                <th class="th-col-lg">Labor Grade</th>
                                <th class="text-center">Mon</th>
                                <th class="text-center">Tue</th>
                                <th class="text-center">Wed</th>
                                <th class="text-center">Thu</th>
                                <th class="text-center">Fri</th>
                                <th class="text-center">Sat</th>
                                <th class="text-center">Sun</th>
                                <th class="text-center">Total</th>
                                <th class="th-col-actions" id="actionsHeader"></th>
                            </tr>
                        </thead>
                        <tbody id="rowsBody"></tbody>
                        <tfoot>
                            <tr class="fw-bold timesheet-tfoot-totals">
                                <td colspan="2" class="ps-4 py-3">Weekly Total Distribution</td>
                                <td class="text-center" id="totalMon">0.0</td>
                                <td class="text-center" id="totalTue">0.0</td>
                                <td class="text-center" id="totalWed">0.0</td>
                                <td class="text-center" id="totalThu">0.0</td>
                                <td class="text-center" id="totalFri">0.0</td>
                                <td class="text-center" id="totalSat">0.0</td>
                                <td class="text-center" id="totalSun">0.0</td>
                                <td class="text-center">
                                    <span class="total-pill" id="totalAll">0.0 hrs</span>
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4 flex-wrap" id="buttonBar">
                <button type="button" class="btn btn-timesheet-add" id="addRowBtn" onclick="addRow()" style="display:none;">+ Add Row</button>
                <button type="button" class="btn btn-timesheet-add" id="saveBtn" onclick="saveChanges()" style="display:none;">Save Changes</button>
                <button type="button" class="btn btn-timesheet-submit" id="resubmitBtn" onclick="resubmitTimesheet()" style="display:none;">Resubmit</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const API = '@Model.ApiBaseUrl';
    const TOKEN = '@Model.JwtToken';
    const TIMESHEET_ID = @Model.Id;

    let currentTimesheet = null;
    let workPackages = [];
    let myLaborGradeLabelForEdit = '—';
    let isEditable = false;

    function authFetch(url, options = {}) {
        options.headers = {
            ...(options.headers || {}),
            'Authorization': `Bearer ${TOKEN}`
        };
        return fetch(url, options).then(res => {
            if (res.status === 401) {
                window.location.href = '/Login';
            }
            return res;
        });
    }

    function esc(str) {
        const div = document.createElement('div');
        div.textContent = str == null ? '' : String(str);
        return div.innerHTML;
    }

    function statusBadge(status) {
        const s = (status || '').toUpperCase();
        if (s === 'APPROVED') return '<span class="badge-approved">APPROVED</span>';
        if (s === 'SUBMITTED') return '<span class="badge-processing">SUBMITTED</span>';
        if (s === 'RETURNED') return '<span class="badge-returned">RETURNED</span>';
        return '<span class="badge-draft">DRAFT</span>';
    }

    function parseHours(val) {
        const n = parseFloat(val);
        return isNaN(n) ? 0 : Math.round(n * 10) / 10;
    }

    async function init() {
        try {
            const tsRes = await authFetch(`${API}/api/timesheets/${TIMESHEET_ID}`);
            if (!tsRes.ok) throw new Error(await tsRes.text());

            currentTimesheet = await tsRes.json();
            const status = (currentTimesheet.status || currentTimesheet.timesheetStatus || '').toUpperCase();
            isEditable = status === 'RETURNED';

            if (isEditable) {
                await Promise.all([
                    loadWorkPackages(),
                    loadEmployeeLaborGradeForEdit(currentTimesheet.empId)
                ]);
            }

            renderPage();
            document.getElementById('loadingArea').style.display = 'none';
            document.getElementById('contentArea').style.display = '';
        } catch (err) {
            document.getElementById('loadingArea').innerHTML = `<span class="timesheet-history-error">Error: ${esc(err.message)}</span>`;
        }
    }

    async function loadWorkPackages() {
        const res = await authFetch(`${API}/api/workpackages/chargeable`);
        if (!res.ok) throw new Error('Could not load work packages.');
        workPackages = await res.json();
    }

    async function loadEmployeeLaborGradeForEdit(empId) {
        if (empId == null || isNaN(empId)) return;
        try {
            const empRes = await authFetch(`${API}/api/employees/${empId}`);
            if (!empRes.ok) throw new Error('Could not load employee profile.');
            const emp = await empRes.json();
            const lgId = emp.labor_grade_id ?? emp.laborGradeId;
            if (lgId == null) {
                myLaborGradeLabelForEdit = '—';
                return;
            }
            const lgRes = await authFetch(`${API}/api/labor-grades/${lgId}`);
            if (!lgRes.ok) throw new Error('Could not load labor grade.');
            const lg = await lgRes.json();
            myLaborGradeLabelForEdit = `${lg.gradeCode} ($${lg.chargeRate})`;
        } catch (err) {
            myLaborGradeLabelForEdit = '—';
            showAlert(`Could not load labor grade: ${err.message}`, 'warning');
        }
    }

    function renderPage() {
        const ts = currentTimesheet;
        const status = (ts.status || ts.timesheetStatus || '').toUpperCase();

        document.getElementById('tsIdDisplay').textContent = ts.tsId || '';
        document.getElementById('empDisplay').textContent = ts.empName || `Emp #${ts.empId}`;
        document.getElementById('approverDisplay').textContent = ts.approverName || (ts.approverId ? `Emp #${ts.approverId}` : '-');
        document.getElementById('statusDisplay').innerHTML = statusBadge(status);
        document.getElementById('weekEndingInput').value = ts.weekEnding || '';
        document.getElementById('weekEndingInput').disabled = !isEditable;

        if (status === 'RETURNED' && ts.returnComment) {
            document.getElementById('returnCommentCard').style.display = '';
            document.getElementById('returnCommentDisplay').textContent = ts.returnComment;
        }

        document.getElementById('addRowBtn').style.display = isEditable ? '' : 'none';
        document.getElementById('saveBtn').style.display = isEditable ? '' : 'none';
        document.getElementById('resubmitBtn').style.display = isEditable ? '' : 'none';
        document.getElementById('actionsHeader').style.display = isEditable ? '' : 'none';

        renderRows(ts.rows || []);
        updateTotals();
    }

    function renderRows(rows) {
        const body = document.getElementById('rowsBody');
        body.innerHTML = '';

        if (!rows.length) {
            body.innerHTML = `<tr><td colspan="11" class="text-center py-4">No rows found.</td></tr>`;
            return;
        }

        rows.forEach(r => body.appendChild(buildRow(r)));
    }

    function buildRow(row) {
        const tr = document.createElement('tr');

        if (isEditable) {
            const wpOptions = buildWpOptions(row.wpId, row.wpName);
            const hr = (cls, value) => `<td><input type="number" class="hr-input ${cls}" step="0.1" min="0" max="24" value="${value ?? 0}" oninput="updateTotals()" /></td>`;

            tr.innerHTML = `
                <td class="ps-3">
                    <select class="form-select form-select-ts wp-select">
                        ${wpOptions}
                    </select>
                </td>
                <td class="ps-2 text-muted small">${esc(myLaborGradeLabelForEdit)}</td>
                ${hr('hr-mon', row.monday)}
                ${hr('hr-tue', row.tuesday)}
                ${hr('hr-wed', row.wednesday)}
                ${hr('hr-thu', row.thursday)}
                ${hr('hr-fri', row.friday)}
                ${hr('hr-sat', row.saturday)}
                ${hr('hr-sun', row.sunday)}
                <td class="text-center fw-bold row-total">0.0</td>
                <td>
                    <button type="button" class="btn btn-link btn-sm timesheet-remove-row" onclick="removeRow(this)">&times;</button>
                </td>
            `;
        } else {
            const dayFields = ['monday','tuesday','wednesday','thursday','friday','saturday','sunday'];
            const total = dayFields.reduce((sum, f) => sum + (Number(row[f]) || 0), 0);

            tr.innerHTML = `
                <td>${esc(row.wpId || '')}${row.wpName ? ' - ' + esc(row.wpName) : ''}</td>
                <td>${esc(row.laborGradeCode || '')}</td>
                <td class="text-center">${row.monday ?? 0}</td>
                <td class="text-center">${row.tuesday ?? 0}</td>
                <td class="text-center">${row.wednesday ?? 0}</td>
                <td class="text-center">${row.thursday ?? 0}</td>
                <td class="text-center">${row.friday ?? 0}</td>
                <td class="text-center">${row.saturday ?? 0}</td>
                <td class="text-center">${row.sunday ?? 0}</td>
                <td class="text-center fw-bold row-total">${total.toFixed(1)}</td>
                <td style="display:none;"></td>
            `;
        }

        return tr;
    }

    function buildWpOptions(selectedId, selectedName) {
        const opts = [];
        const currentExists = workPackages.some(wp => wp.wpId === selectedId);

        opts.push(`<option value="">Select...</option>`);

        if (selectedId && !currentExists) {
            opts.push(`<option value="${esc(selectedId)}" selected>${esc(selectedId)} - ${esc(selectedName || '')}</option>`);
        }

        workPackages.forEach(wp => {
            const selected = wp.wpId === selectedId ? 'selected' : '';
            opts.push(`<option value="${esc(wp.wpId)}" ${selected}>${esc(wp.wpId)} - ${esc(wp.wpName || '')}</option>`);
        });

        return opts.join('');
    }

    function addRow() {
        if (!isEditable) return;
        const body = document.getElementById('rowsBody');
        body.appendChild(buildRow({
            wpId: '',
            wpName: '',
            laborGradeId: '',
            laborGradeCode: '',
            monday: 0,
            tuesday: 0,
            wednesday: 0,
            thursday: 0,
            friday: 0,
            saturday: 0,
            sunday: 0
        }));
        updateTotals();
    }

    function removeRow(btn) {
        const body = document.getElementById('rowsBody');
        if (body.querySelectorAll('tr').length <= 1) {
            showAlert('Timesheet must contain at least one row.', 'warning');
            return;
        }
        btn.closest('tr').remove();
        updateTotals();
    }

    function updateTotals() {
        const rows = Array.from(document.querySelectorAll('#rowsBody tr'));
        const days = ['mon', 'tue', 'wed', 'thu', 'fri', 'sat', 'sun'];

        if (!isEditable) {
            let totals = { mon:0, tue:0, wed:0, thu:0, fri:0, sat:0, sun:0 };
            rows.forEach(row => {
                const cells = row.querySelectorAll('td');
                if (cells.length < 9) return;
                totals.mon += parseFloat(cells[2].textContent) || 0;
                totals.tue += parseFloat(cells[3].textContent) || 0;
                totals.wed += parseFloat(cells[4].textContent) || 0;
                totals.thu += parseFloat(cells[5].textContent) || 0;
                totals.fri += parseFloat(cells[6].textContent) || 0;
                totals.sat += parseFloat(cells[7].textContent) || 0;
                totals.sun += parseFloat(cells[8].textContent) || 0;
            });

            const grand = totals.mon + totals.tue + totals.wed + totals.thu + totals.fri + totals.sat + totals.sun;
            document.getElementById('totalMon').textContent = totals.mon.toFixed(1);
            document.getElementById('totalTue').textContent = totals.tue.toFixed(1);
            document.getElementById('totalWed').textContent = totals.wed.toFixed(1);
            document.getElementById('totalThu').textContent = totals.thu.toFixed(1);
            document.getElementById('totalFri').textContent = totals.fri.toFixed(1);
            document.getElementById('totalSat').textContent = totals.sat.toFixed(1);
            document.getElementById('totalSun').textContent = totals.sun.toFixed(1);
            document.getElementById('totalAll').textContent = `${grand.toFixed(1)} hrs`;
            return;
        }

        let grandTotal = 0;
        days.forEach(day => {
            let daySum = 0;
            document.querySelectorAll(`.hr-${day}`).forEach(input => {
                daySum += parseFloat(input.value) || 0;
            });
            document.getElementById(`total${day.charAt(0).toUpperCase() + day.slice(1)}`).textContent = daySum.toFixed(1);
            grandTotal += daySum;
        });

        document.querySelectorAll('#rowsBody tr').forEach(row => {
            let rowSum = 0;
            row.querySelectorAll('.hr-input').forEach(i => rowSum += parseFloat(i.value) || 0);
            const totalCell = row.querySelector('.row-total');
            if (totalCell) totalCell.textContent = rowSum.toFixed(1);
        });

        document.getElementById('totalAll').textContent = `${grandTotal.toFixed(1)} hrs`;
    }

    function buildRequestDto() {
        const rows = [];
        let valid = true;

        document.querySelectorAll('#rowsBody tr').forEach((tr, idx) => {
            const wpId = tr.querySelector('.wp-select')?.value;

            if (!wpId) {
                showAlert(`Row ${idx + 1}: Please select a work package.`, 'warning');
                valid = false;
                return;
            }

            rows.push({
                wpId,
                monday: parseHours(tr.querySelector('.hr-mon')?.value),
                tuesday: parseHours(tr.querySelector('.hr-tue')?.value),
                wednesday: parseHours(tr.querySelector('.hr-wed')?.value),
                thursday: parseHours(tr.querySelector('.hr-thu')?.value),
                friday: parseHours(tr.querySelector('.hr-fri')?.value),
                saturday: parseHours(tr.querySelector('.hr-sat')?.value),
                sunday: parseHours(tr.querySelector('.hr-sun')?.value)
            });
        });

        if (!valid) return null;

        return {
            empId: currentTimesheet.empId,
            weekEnding: document.getElementById('weekEndingInput').value,
            rows
        };
    }

    async function saveChanges() {
        clearAlert();
        const dto = buildRequestDto();
        if (!dto) return;

        try {
            const res = await authFetch(`${API}/api/timesheets/${TIMESHEET_ID}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dto)
            });

            if (!res.ok) throw new Error(await res.text());

            currentTimesheet = await res.json();
            showAlert('Changes saved successfully.', 'success');
        } catch (err) {
            showAlert(`Save failed: ${err.message}`, 'danger');
        }
    }

    async function resubmitTimesheet() {
        clearAlert();

        const dto = buildRequestDto();
        if (!dto) return;

        const confirmed = confirm('Resubmit this returned timesheet?');
        if (!confirmed) return;

        try {
            const updateRes = await authFetch(`${API}/api/timesheets/${TIMESHEET_ID}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dto)
            });

            if (!updateRes.ok) throw new Error(await updateRes.text());

            const submitRes = await authFetch(`${API}/api/timesheets/${TIMESHEET_ID}/submit`, {
                method: 'PUT'
            });

            if (!submitRes.ok) throw new Error(await submitRes.text());

            window.location.href = '/Timesheets/Index';
        } catch (err) {
            showAlert(`Resubmit failed: ${err.message}`, 'danger');
        }
    }

    function showAlert(msg, type) {
        document.getElementById('alertArea').innerHTML = `
            <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                ${esc(msg)}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>`;
    }

    function clearAlert() {
        document.getElementById('alertArea').innerHTML = '';
    }

    document.addEventListener('DOMContentLoaded', init);
</script>
}
