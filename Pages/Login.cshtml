@page
@model frontend.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

@section Head {
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
}

<div class="login-page">
    <div class="login-page-inner">
        <div class="login-card">
            <h1 class="login-title">Sign in</h1>
            <p class="login-subtitle">Enter your employee credentials to continue.</p>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="login-alert" role="alert">
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                <div class="login-field">
                    <label asp-for="Input.EmpId" class="login-label">Employee ID</label>
                    <input asp-for="Input.EmpId" type="text" class="login-input" placeholder="Enter your employee ID" autocomplete="username" />
                </div>

                <div class="login-field">
                    <label asp-for="Input.Password" class="login-label">Password</label>
                    <input asp-for="Input.Password" type="password" class="login-input" placeholder="Enter your password" autocomplete="current-password" />
                </div>

                <button type="submit" class="login-btn-primary">
                    Log in
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>sessionStorage.removeItem('canAccessApprover');</script>
}
