@page
@model IndexModel
@using frontend.model

@{
    ViewData["Title"] = "Employees";
    var employees = ViewData["Employees"] as List<Employee> ?? new List<Employee>();
}

@section Head {
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
}

<div class="employees-page">
<div class="employees-canvas">
    @if (TempData["DeleteError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <strong>Delete failed:</strong> @TempData["DeleteError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["UpdateSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <strong>Success:</strong> @TempData["UpdateSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="employees-header">
        <div class="employees-header-row">
            <div>
                <h1 class="employees-page-title">Employee List</h1>
                <p class="employees-page-subtitle mb-0 mt-1">Manage employees and roles</p>
            </div>
            <a asp-page="/Employee/Create" class="employees-btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" height="24" viewBox="0 -960 960 960" width="24" aria-hidden="true"><path d="M720-400v-120H600v-80h120v-120h80v120h120v80H800v120h-80ZM247-527q-47-47-47-113t47-113q47-47 113-47t113 47q47 47 47 113t-47 113q-47 47-113 47t-113-47ZM40-160v-112q0-34 17.5-62.5T104-378q62-31 126-46.5T360-440q66 0 130 15.5T616-378q29 15 46.5 43.5T680-272v112H40Zm80-80h480v-32q0-11-5.5-20T580-306q-54-27-109-40.5T360-360q-56 0-111 13.5T140-306q-9 5-14.5 14t-5.5 20v32Zm296.5-343.5Q440-607 440-640t-23.5-56.5Q393-720 360-720t-56.5 23.5Q280-673 280-640t23.5 56.5Q327-560 360-560t56.5-23.5ZM360-640Zm0 400Z"/></svg>
                Add Employee
            </a>
        </div>
    </div>

    <div class="employees-toolbar d-flex align-items-center gap-3 flex-wrap">
        <div class="input-group flex-grow-1 employees-search-group">
            <span class="input-group-text">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                </svg>
            </span>
            <input type="text" id="employeeSearchInput" class="form-control shadow-none"
                   placeholder="Search by name, ID or role..."
                   oninput="filterEmployees()">
        </div>
        <div class="d-flex align-items-center gap-2">
            <label class="employees-toolbar-label text-nowrap" for="roleFilterSelect">Filter by Role:</label>
            <select id="roleFilterSelect" class="form-select form-select-sm shadow-none employees-toolbar-select"
                    onchange="filterEmployees()">
                <option value="">All Roles</option>
                <option value="ADMIN">Admin</option>
                <option value="EMPLOYEE">Employee</option>
                <option value="OPERATIONS_MANAGER">Operations Manager</option>
                <option value="HR">HR</option>
            </select>
        </div>
    </div>

    <div class="employees-table-shell">
        <table class="table table-hover mb-0 employees-table" id="employeeTable">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Employee ID</th>
                    <th>Role</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var employee in employees)
                {
                    var roleBadgeClass = employee.systemRole switch
                    {
                        "ADMIN" => "employees-role-badge--admin",
                        "EMPLOYEE" => "employees-role-badge--employee",
                        "OPERATIONS_MANAGER" => "employees-role-badge--operations",
                        "HR" => "employees-role-badge--hr",
                        _ => "employees-role-badge--default"
                    };
                    <tr class="employee-row" data-name="@employee.empFirstName @employee.empLastName"
                        data-id="OA-@employee.empId.ToString().PadLeft(4, '0')" data-role="@employee.systemRole">
                        <td>
                            <span class="employees-name">
                                @employee.empFirstName @employee.empLastName
                            </span>
                        </td>
                        <td class="employees-id-cell">
                            OA-@employee.empId.ToString().PadLeft(4, '0')
                        </td>
                        <td>
                            <span class="badge rounded-pill employees-role-badge @roleBadgeClass">
                                @employee.systemRole
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-page="/Employee/Update" asp-route-id="@employee.empId"
                               class="employees-action-btn" title="Edit">
                               <svg xmlns="http://www.w3.org/2000/svg" height="24" viewBox="0 -960 960 960" width="24" aria-hidden="true"><path d="M200-200h57l391-391-57-57-391 391v57Zm-80 80v-170l528-527q12-11 26.5-17t30.5-6q16 0 31 6t26 18l55 56q12 11 17.5 26t5.5 30q0 16-5.5 30.5T817-647L290-120H120Zm640-584-56-56 56 56Zm-141 85-28-29 57 57-29-28Z"/></svg>
                            </a>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@employee.empId"
                                  class="d-inline"
                                  onsubmit="return confirm('Are you sure you want to delete this employee?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="employees-action-btn employees-action-btn--danger" title="Delete">
                                    <svg xmlns="http://www.w3.org/2000/svg" height="24" viewBox="0 -960 960 960" width="24" aria-hidden="true"><path d="M280-120q-33 0-56.5-23.5T200-200v-520h-40v-80h200v-40h240v40h200v80h-40v520q0 33-23.5 56.5T680-120H280Zm400-600H280v520h400v-520ZM360-280h80v-360h-80v360Zm160 0h80v-360h-80v360ZM280-720v520-520Z"/></svg>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <small class="employees-footer-note">Showing @employees.Count employee(s)</small>
    </div>
</div>
</div>

@section Scripts {
    <script>
        function filterEmployees() {
            const searchValue = document.getElementById('employeeSearchInput').value.toLowerCase();
            const roleValue = document.getElementById('roleFilterSelect').value;
            const rows = document.querySelectorAll('.employee-row');

            rows.forEach(row => {
                const name = (row.getAttribute('data-name') || '').toLowerCase();
                const id = (row.getAttribute('data-id') || '').toLowerCase();
                const role = (row.getAttribute('data-role') || '');

                const matchesSearch = name.includes(searchValue) || id.includes(searchValue) || role.toLowerCase().includes(searchValue);
                const matchesRole = !roleValue || role === roleValue;

                row.style.display = (matchesSearch && matchesRole) ? '' : 'none';
            });
        }
    </script>
}
