@page
@model CreateModel
@using frontend.model

@{
    ViewData["Title"] = "New Employee";
    var employees = ViewData["Employees"] as List<Employee> ?? new List<Employee>();
    var laborGrades = ViewData["LaborGrades"] as List<LaborGrade> ?? new List<LaborGrade>();
}

@section Head {
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
}

<div class="employees-page">
<div class="employees-canvas">
    <nav aria-label="breadcrumb" class="employees-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-page="/Employee/Index">Employees</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">New Employee</li>
        </ol>
    </nav>

    <div class="employees-header">
        <h1 class="employees-page-title">Employee Details</h1>
        <p class="employees-page-subtitle mb-0 mt-1">Create employee information</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 p-4 p-md-5 employees-form-card">
        <form method="post">
            <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                    <label asp-for="employeeDto.firstName" class="form-label employees-field-label">First Name</label>
                    <input type="text" class="form-control employees-input"
                           asp-for="employeeDto.firstName"
                           placeholder="e.g. Julian"
                           required>
                </div>
                <div class="col-md-6">
                    <label asp-for="employeeDto.lastName" class="form-label employees-field-label">Last Name</label>
                    <input type="text" class="form-control employees-input"
                           asp-for="employeeDto.lastName"
                           placeholder="e.g. Thorne"
                           required>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-12">
                    <label asp-for="employeeDto.password" class="form-label employees-field-label">Password</label>
                    <input type="password" class="form-control employees-input"
                           asp-for="employeeDto.password"
                           placeholder="Enter password"
                           required>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                    <label asp-for="employeeDto.systemRole" class="form-label employees-field-label">Role</label>
                    <select class="form-select employees-select"
                            asp-for="employeeDto.systemRole"
                            required>
                        <option value="">Select Role</option>
                        <option value="ADMIN">Admin</option>
                        <option value="EMPLOYEE">Employee</option>
                        <option value="OPERATIONS_MANAGER">Operations Manager</option>
                        <option value="HR">HR</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="employeeDto.laborGradeId" class="form-label employees-field-label">Labor Grade</label>
                    <select class="form-select employees-select"
                            asp-for="employeeDto.laborGradeId"
                            required>
                        <option value="">Select Labor Grade</option>
                        @foreach (var laborGrade in laborGrades)
                        {
                            <option value="@laborGrade.laborGradeId">@laborGrade.gradeCode</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <label asp-for="employeeDto.supervisorId" class="form-label employees-field-label">Supervisor</label>
                    <select class="form-select employees-select"
                            asp-for="employeeDto.supervisorId"
                            required>
                        <option value="">Select Supervisor</option>
                        @foreach (var employee in employees)
                        {
                            <option value="@employee.empId">@employee.empFirstName @employee.empLastName</option>
                        }
                    </select>
                </div>
            </div>

            <div class="d-flex justify-content-center gap-3 mt-4 employees-form-actions">
                <a asp-page="/Employee/Index" class="employees-btn-secondary">
                    Cancel
                </a>
                <button type="submit" class="employees-btn-primary">
                    Save Employee
                </button>
            </div>
        </form>
    </div>
</div>
</div>
