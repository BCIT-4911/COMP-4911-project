@page
@model frontend.Pages.LaborGrades.CreateModel

@{
    var isEdit = Model.LaborGradeId.HasValue;
    ViewData["Title"] = isEdit ? "Edit Labor Grade" : "Add Labor Grade";
}

<div class="container py-4">
    <div class="mb-4">
        <a asp-page="/LaborGrades/Index" class="text-decoration-none d-inline-flex align-items-center gap-1"
           style="color: #607E6C;">
            <svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="#607E6C">
                <path d="M400-80 0-480l400-400 71 71-329 329 329 329-71 71Z"/>
            </svg>
            Back to Labor Grades
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="rounded-3 p-4" style="border: 1px solid #dce8d5; background-color: #fff;">
                <h2 class="fw-bold mb-4" style="color: #607E6C;">
                    @(isEdit ? "Edit Labor Grade" : "Add Labor Grade")
                </h2>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }

                <form method="post">
                    <input type="hidden" asp-for="LaborGradeId" />

                    <div class="mb-3">
                        <label asp-for="GradeCode" class="form-label fw-semibold" style="color: #555;">
                            Grade Code
                        </label>
                        <input asp-for="GradeCode" class="form-control" maxlength="2"
                               placeholder="e.g. P1, P2, DS"
                               style="border-color: #dce8d5;" />
                        <small class="text-muted">Max 2 characters</small>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ChargeRate" class="form-label fw-semibold" style="color: #555;">
                            Charge Rate ($)
                        </label>
                        <input asp-for="ChargeRate" class="form-control" type="number" step="0.01" min="0"
                               placeholder="e.g. 85.00"
                               style="border-color: #dce8d5;" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn text-white px-4"
                                style="background-color: #607E6C;">
                            @(isEdit ? "Update" : "Create")
                        </button>
                        <a asp-page="/LaborGrades/Index" class="btn btn-outline-secondary px-4">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
