@page
@model EmployeesModel
@using frontend.model

@{
    ViewData["Title"] = "Employees";
}

<div class="container py-4">
    <h1 class="display-6">Employees</h1>
    <p class="text-muted">HR only. Team Onboarding implements employee list and registration.</p>
    <div>
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>System Role</th>
                    <th>Vacation Sick Balance</th>
                    <th>Expected Weekly Hours</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var employee in (List<Employee>)ViewData["Employees"])
                {
                    <tr>
                        <td>@employee.empId</td>
                        <td>@employee.empFirstName</td>
                        <td>@employee.empLastName</td>
                        <td>@employee.systemRole</td>
                        <td>@employee.vacationSickBalance</td>
                        <td>@employee.expectedWeeklyHours</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div>
        <form method="post">
            <div class="form-group">
                <label asp-for="employeeDto.firstName">First Name</label>
                <input type="text" class="form-control" asp-for="employeeDto.firstName" placeholder="Enter first name">
            </div>
            <div class="form-group">
                <label asp-for="employeeDto.lastName">Last Name</label>
                <input type="text" class="form-control" asp-for="employeeDto.lastName" placeholder="Enter last name">
            </div>
            <div class="form-group">
                <label asp-for="employeeDto.password">Password</label>
                <input type="text" class="form-control" asp-for="employeeDto.password" placeholder="Enter password">
            </div>
            <div class="form-group">
                <label asp-for="employeeDto.laborGradeId">Labor Grade</label>
                <select class="form-select" asp-for="employeeDto.laborGradeId">
                    @foreach (var laborGrade in (List<LaborGrade>)ViewData["LaborGrades"])
                    {
                        <option value="@laborGrade.laborGradeId">@laborGrade.gradeCode</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label asp-for="employeeDto.supervisorId">Supervisor</label>
                <select class="form-select" asp-for="employeeDto.supervisorId">
                    @foreach (var employee in (List<Employee>)ViewData["Employees"])
                    {
                        @if (employee.systemRole == "OPERATIONS_MANAGER")
                        {
                            <option value="@employee.empId">@employee.empFirstName @employee.empLastName</option>
                        }
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Add Employee</button>
        </form>
    </div>
</div>
