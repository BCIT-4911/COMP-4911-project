@page
@model frontend.Pages.EarnedValue.IndexModel
@{
    ViewData["Title"] = "Earned Value Report";
}

@section Head {
    <link rel="stylesheet" href="~/css/earned-value.css" asp-append-version="true" />
}

@functions {
    private static string Money(decimal value) => string.Format(System.Globalization.CultureInfo.InvariantCulture, "${0:N0}", value);
    private static string SignedMoney(decimal value) => string.Format(System.Globalization.CultureInfo.InvariantCulture, "{0}{1:N0}", value >= 0 ? "+" : "-", Math.Abs(value));
    private static string VarianceClass(decimal value) => value < 0 ? "ev-var-negative" : "ev-var-positive";
}

<div class="ev-shell">
    <section class="ev-hero">
        <h1 class="ev-title">Earned Value Report</h1>
        <p class="ev-subtitle">Track project performance and budget compliance across active work packages.</p>
    </section>

    <section class="ev-filter-panel">
        <form method="get" class="ev-filter-form">
            <div>
                <label class="ev-field-label" asp-for="SelectedProjectId">Project</label>
                <select class="ev-select" asp-for="SelectedProjectId">
                    <option value="">Select a project</option>
                    @foreach (var project in Model.Projects)
                    {
                        <option value="@project.Id">@project.Name</option>
                    }
                </select>
            </div>

            <div>
                <label class="ev-field-label" asp-for="SelectedWorkPackageId">Work Package</label>
                <select class="ev-select" asp-for="SelectedWorkPackageId" disabled="@(!Model.HasWorkPackageFilter)">
                    <option value="">All Work Packages</option>
                    @foreach (var workPackage in Model.WorkPackageOptions)
                    {
                        <option value="@workPackage.Id">@workPackage.Name</option>
                    }
                </select>
            </div>

            <button type="submit" class="ev-button">View Report</button>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="ev-error">@Model.ErrorMessage</div>
        }
    </section>

    @if (!Model.HasReport)
    {
        <section class="ev-empty">
            <div class="ev-empty-title">Choose a project to generate the report</div>
            <p class="mb-0">The table and performance cards will appear here after you select a project and click <strong>View Report</strong>.</p>
        </section>
    }
    else
    {
        <section class="ev-report" data-ev-root data-as-of="@DateTime.Today.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture)">
            <div class="ev-summary-grid">
                <article class="ev-card">
                    <div class="ev-card-label">BAC</div>
                    <div class="ev-card-value">@Money(Model.DisplayReport!.ProjectBac)</div>
                    <div class="ev-card-note">Budget At Completion</div>
                </article>

                <article class="ev-card">
                    <div class="ev-card-label">BCWS</div>
                    <div class="ev-card-value">@Money(Model.DisplayReport!.ProjectBcws)</div>
                    <div class="ev-card-note">Planned Value (PV)</div>
                </article>

                <article class="ev-card">
                    <div class="ev-card-label">BCWP</div>
                    <div class="ev-card-value">@Money(Model.DisplayReport!.ProjectBcwp)</div>
                    <div class="ev-card-note">Earned Value (EV)</div>
                </article>

                <article class="ev-card">
                    <div class="ev-card-label">ACWP</div>
                    <div class="ev-card-value">@Money(Model.DisplayReport!.ProjectAcwp)</div>
                    <div class="ev-card-note">Actual Cost (AC)</div>
                </article>
            </div>

            <div class="ev-table-shell">
                <table class="ev-table">
                    <thead>
                        <tr>
                            <th>WP ID</th>
                            <th>Work Description</th>
                            <th>EV Method</th>
                            <th class="ev-num">BAC</th>
                            <th class="ev-num">BCWS</th>
                            <th class="ev-num">BCWP</th>
                            <th class="ev-num">ACWP</th>
                            <th class="ev-num">ETC</th>
                            <th class="ev-num">SV</th>
                            <th class="ev-num">CV</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var wp in Model.DisplayReport!.WorkPackages)
                        {
                            <tr class="ev-clickable-row"
                                tabindex="0"
                                role="button"
                                data-ev-modal-open
                                data-wp-id="@wp.WpId"
                                data-wp-name="@wp.Description"
                                aria-label="Open monthly performance details for @wp.Description">
                                <td class="ev-wp-id">@wp.WpId</td>
                                <td class="ev-desc">@wp.Description</td>
                                <td>@wp.EvMethod</td>
                                <td class="ev-num">@Money(wp.Bac)</td>
                                <td class="ev-num">@Money(wp.Bcws)</td>
                                <td class="ev-num">@Money(wp.Bcwp)</td>
                                <td class="ev-num">@Money(wp.Acwp)</td>
                                <td class="ev-num">@Money(wp.Etc)</td>
                                <td class="ev-num @VarianceClass(wp.Sv)">@SignedMoney(wp.Sv)</td>
                                <td class="ev-num @VarianceClass(wp.Cv)">@SignedMoney(wp.Cv)</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="8">Total Variances</td>
                            <td class="ev-num @VarianceClass(Model.DisplayReport.TotalSv)">@SignedMoney(Model.DisplayReport.TotalSv)</td>
                            <td class="ev-num @VarianceClass(Model.DisplayReport.TotalCv)">@SignedMoney(Model.DisplayReport.TotalCv)</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </section>
    }
</div>

<div class="ev-modal-backdrop" data-ev-modal-backdrop hidden>
    <section class="ev-modal" role="dialog" aria-modal="true" aria-labelledby="ev-modal-title">
        <div class="ev-modal-header">
            <div>
                <div class="ev-modal-kicker">Work Package Detail</div>
                <h2 class="ev-modal-title" id="ev-modal-title">Work Package Monthly Performance</h2>
            </div>
            <button type="button" class="ev-modal-close" data-ev-modal-close aria-label="Close">X</button>
        </div>

        <div class="ev-modal-body">
            <div class="ev-modal-status" data-ev-modal-status>Loading work package details...</div>

            <div class="ev-modal-content" data-ev-modal-content hidden>
                <section class="ev-visual-panel">
                    <div class="ev-panel-kicker">Visual Analysis</div>
                    <div class="ev-panel-title">Planned vs. Earned Value</div>
                    <div class="ev-chart-legend">
                        <span><i class="ev-legend-swatch ev-legend-planned"></i>BCWS (Planned)</span>
                        <span><i class="ev-legend-swatch ev-legend-earned"></i>BCWP (Earned)</span>
                    </div>
                    <div class="ev-chart-shell">
                        <div class="ev-chart" data-ev-chart></div>
                    </div>
                </section>

                <section class="ev-breakdown-panel">
                    <div class="ev-panel-kicker">Financial Data</div>
                    <div class="ev-panel-title">Monthly Performance Breakdown</div>
                    <div class="ev-metrics-strip" data-ev-metric-summary></div>
                    <div class="ev-breakdown-shell">
                        <table class="ev-breakdown-table" data-ev-breakdown-table></table>
                    </div>
                </section>
            </div>
        </div>

        <div class="ev-modal-footer">
            <button type="button" class="ev-button" data-ev-modal-close>Close</button>
        </div>
    </section>
</div>

@section Scripts {
    <script src="~/js/earned-value.js" asp-append-version="true"></script>
}
