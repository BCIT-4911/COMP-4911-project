@page
@model frontend.Pages.EarnedValue.LaborReportModel
@{
    ViewData["Title"] = "Labor Report";
}

@section Head {
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
}

<div class="labor-report-page">
    <div class="labor-report-canvas">

        <div class="labor-report-header">
            <h1 class="labor-report-page-title">Labor Report</h1>
            <p class="labor-report-page-subtitle mb-0 mt-1">Detailed breakdown of project hours and labor metrics.</p>
        </div>

        <!-- ================================================================
             Filter card
        ================================================================ -->
        <div class="lr-filter-card">
            <form method="get">
                <div class="row g-3 align-items-end">

                    <!-- Project dropdown -->
                    <div class="col-md-6 col-lg-4">
                        <label class="lr-filter-label">Project</label>
                        <select class="lr-filter-select" asp-for="SelectedProjectId">
                            <option value="">All Projects</option>
                            @foreach (var p in Model.Projects)
                            {
                                <option value="@p.ProjectId"
                                         selected="@(Model.SelectedProjectId == p.ProjectId)">
                                    @p.ProjectName
                                </option>
                            }
                        </select>
                    </div>

                    <!-- Employee dropdown -->
                    <div class="col-md-6 col-lg-3">
                        <label class="lr-filter-label">Employee</label>
                        <select class="lr-filter-select" asp-for="SelectedEmployeeId">
                            <option value="">All Employees</option>
                            @foreach (var e in Model.Employees)
                            {
                                <option value="@e.empId"
                                        selected="@(Model.SelectedEmployeeId == e.empId)">
                                    @e.empFirstName @e.empLastName
                                </option>
                            }
                        </select>
                    </div>

                    <!-- Week Ending date picker -->
                    <div class="col-md-6 col-lg-3">
                        <label class="lr-filter-label">Week Ending</label>
                        <input type="date"
                               class="lr-filter-input"
                               asp-for="WeekEnding"
                               value="@Model.WeekEnding" />
                    </div>

                    <!-- Submit button -->
                    <div class="col-md-6 col-lg-2 d-flex align-items-end">
                        <button type="submit" class="lr-btn-view w-100">
                            <!-- search icon -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                 fill="currentColor" viewBox="0 0 16 16">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zm-5.242 1.156a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z"/>
                            </svg>
                            View Report
                        </button>
                    </div>

                </div>
            </form>
        </div>

        <!-- ================================================================
             Error message
        ================================================================ -->
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                @Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (Model.HasResults && Model.Summary != null)
        {
            <!-- ================================================================
                 Summary stat cards
            ================================================================ -->
            <div class="row g-3 mb-4">

                <!-- Total Hours -->
                <div class="col-md-4">
                    <div class="lr-stat-card">
                        <div class="lr-stat-label">
                            <!-- clock icon -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                 fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
                                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
                            </svg>
                            Total Hours
                        </div>
                        <div class="lr-stat-value">@Model.Summary.TotalHours.ToString("0.0")</div>
                        <div class="lr-stat-sub">
                            @if (Model.Summary.HoursChangePercent >= 0)
                            {
                                <span>+@Model.Summary.HoursChangePercent.ToString("0")% from previous week</span>
                            }
                            else
                            {
                                <span>@Model.Summary.HoursChangePercent.ToString("0")% from previous week</span>
                            }
                        </div>
                    </div>
                </div>

                <!-- Overtime -->
                <div class="col-md-4">
                    <div class="lr-stat-card lr-stat-card--overtime">
                        <div class="lr-stat-label">
                            <!-- warning triangle icon -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                 fill="currentColor" viewBox="0 0 16 16">
                                <path d="M7.938 2.016A.13.13 0 0 1 8.002 2a.13.13 0 0 1 .063.016.146.146 0 0 1 .054.057l6.857 11.667c.036.06.035.124.002.183a.163.163 0 0 1-.054.06.116.116 0 0 1-.066.017H1.146a.115.115 0 0 1-.066-.017.163.163 0 0 1-.054-.06.176.176 0 0 1 .002-.183L7.884 2.073a.147.147 0 0 1 .054-.057zm1.044-.45a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566z"/>
                                <path d="M7.002 12a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 5.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995z"/>
                            </svg>
                            Overtime
                        </div>
                        <div class="lr-stat-value lr-stat-value--accent">
                            @Model.Summary.OvertimeHours.ToString("0.0")
                        </div>
                        @if (Model.Summary.PendingApprovalHours > 0)
                        {
                            <div class="lr-stat-sub text-warning">
                                Requires approval for @Model.Summary.PendingApprovalHours.ToString("0") hours
                            </div>
                        }
                        else
                        {
                            <div class="lr-stat-sub">No pending approvals</div>
                        }
                    </div>
                </div>

                <!-- Work Packages -->
                <div class="col-md-4">
                    <div class="lr-stat-card lr-stat-card--wp">
                        <div class="lr-stat-label">
                            <!-- calendar icon -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                 fill="currentColor" viewBox="0 0 16 16">
                                <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
                            </svg>
                            Work Packages
                        </div>
                        <div class="lr-stat-value">
                            @Model.Summary.ActiveWorkPackages
                        </div>
                        <div class="lr-stat-sub">Active this period</div>
                    </div>
                </div>
            </div>

            <!-- ================================================================
                 Labor Details table
            ================================================================ -->
            <div class="lr-table-card">
                <div class="lr-table-card-header">Labor Details</div>

                <div class="table-responsive">
                    <table class="lr-table">
                        <thead>
                            <tr>
                                <th>Employee</th>
                                <th>Work Package</th>
                                <th>Labor Grade</th>
                                <th>Hours</th>
                                <th>Week Ending</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Rows.Count == 0)
                            {
                                <tr>
                                    <td colspan="6">
                                        <div class="lr-empty-state">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48"
                                                 fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h12zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2z"/>
                                                <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                                            </svg>
                                            <p>No timesheet rows found for the selected filters.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var row in Model.Rows)
                                {
                                    // Build initials for avatar
                                    var parts    = (row.EmployeeName ?? "").Split(' ', 2);
                                    var initials = parts.Length >= 2
                                        ? $"{parts[0][0]}{parts[1][0]}"
                                        : row.EmployeeName?.Length >= 2
                                            ? row.EmployeeName[..2]
                                            : "??";

                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <span class="lr-avatar">@initials.ToUpper()</span>
                                                <span>@row.EmployeeName</span>
                                            </div>
                                        </td>
                                        <td>@row.WorkPackageName</td>
                                        <td>@row.LaborGradeCode</td>
                                        <td class="lr-hours">@row.Hours.ToString("0.0")</td>
                                        <td>@row.WeekEnding.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            @{
                                                var statusUpper = (row.StatusLabel ?? "").ToUpperInvariant();
                                                var badgeClass = statusUpper switch
                                                {
                                                    "APPROVED"  => "lr-badge-approved",
                                                    "PENDING"   => "lr-badge-pending",
                                                    "SUBMITTED" => "lr-badge-submitted",
                                                    "RETURNED"  => "lr-badge-returned",
                                                    _           => "lr-badge-draft"
                                                };
                                            }
                                            <span class="lr-badge @badgeClass">@row.StatusLabel</span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>

                        @if (Model.Rows.Count > 0)
                        {
                            <tfoot>
                                <tr class="lr-totals-row">
                                    <td colspan="3" class="text-end">TOTALS</td>
                                    <td class="lr-hours">@Model.TotalHours.ToString("0.0")</td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>
        }
        else if (!Model.HasResults && string.IsNullOrEmpty(Model.ErrorMessage) && !string.IsNullOrWhiteSpace(Model.WeekEnding))
        {
            <!-- Week ending was provided but API returned nothing -->
            <div class="lr-table-card">
                <div class="lr-empty-state">
                    <p>No labor data found for the selected filters.</p>
                </div>
            </div>
        }
        else if (string.IsNullOrWhiteSpace(Model.WeekEnding) && string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <!-- First load — prompt the user to run the report -->
            <div class="lr-table-card">
                <div class="lr-empty-state">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48"
                         fill="currentColor" viewBox="0 0 16 16">
                        <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5z"/>
                    </svg>
                    <p class="mt-2 mb-0">Select a <strong>Week Ending</strong> date above and click <strong>View Report</strong> to load labor data.</p>
                </div>
            </div>
        }

    </div>
</div>
