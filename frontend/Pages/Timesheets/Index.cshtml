@page
@model frontend.Pages.Timesheets.IndexModel
@{
    ViewData["Title"] = "Timesheet";
}

<style>
    :root {
        --brand-green: #4d604d;
        --header-sage: #f5f7f0;
        --dropdown-sage: #ecf3e6;
        --border-color: #d1dbca;
        --text-main: #1e293b;
        --text-muted: #64748b;
    }

    body { background-color: #fcfdfb; font-family: 'Inter', sans-serif; color: var(--text-main); }

    .info-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 1.5rem 2rem;
    }
    .info-label {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-muted);
        letter-spacing: 0.05em;
        margin-bottom: 4px;
    }
    .info-value { font-size: 1.1rem; font-weight: 500; }

    .timesheet-container {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        margin-top: 1.5rem;
    }
    .table-ts thead th {
        background-color: var(--header-sage);
        color: #7c8b7c;
        font-size: 0.65rem;
        text-transform: uppercase;
        font-weight: 700;
        padding: 1rem;
        border-bottom: 1px solid var(--border-color);
    }
    .form-select-ts {
        background-color: var(--dropdown-sage) !important;
        border: 1px solid var(--border-color) !important;
        border-radius: 8px;
        font-size: 0.85rem;
        padding: 0.4rem 0.6rem;
        color: #3d4d3d;
    }
    .hr-input {
        border: none;
        background: transparent;
        text-align: center;
        width: 100%;
        font-weight: 500;
    }
    .hr-input.zero { color: #cbd5e1; }

    .btn-submit { background-color: var(--brand-green); color: white; border: none; padding: 0.6rem 1.5rem; border-radius: 8px; font-weight: 500; }
    .btn-add { border: 1px solid #cbd5e1; background: white; color: var(--text-main); border-radius: 8px; padding: 0.6rem 1.25rem; }

    .total-pill {
        background-color: var(--brand-green);
        color: white;
        padding: 6px 16px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.85rem;
        display: inline-block;
    }

    .badge-approved { background-color: #dcfce7; color: #166534; font-size: 0.6rem; font-weight: 800; padding: 4px 8px; border-radius: 6px; }
    .badge-processing { background-color: #f1f5f9; color: #475569; font-size: 0.6rem; font-weight: 800; padding: 4px 8px; border-radius: 6px; }
    .badge-returned { background-color: #fee2e2; color: #dc2626; font-size: 0.6rem; font-weight: 800; padding: 4px 8px; border-radius: 6px; }
    .badge-draft { background-color: #f1f5f9; color: #475569; font-size: 0.6rem; font-weight: 800; padding: 4px 8px; border-radius: 6px; }
</style>

<div class="container pb-5 pt-4">

    <!-- Alert area -->
    <div id="alertArea"></div>

    <div class="d-flex align-items-end justify-content-between mb-4">
        <div>
            <h1 class="fw-bold mb-1" style="font-size: 2rem;">Timesheet</h1>
            <p class="text-muted mb-0">Record and manage your weekly labor distribution.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-add shadow-sm" onclick="addRow()">+ Add Row</button>
            <button class="btn btn-submit shadow-sm" onclick="submitTimesheet()">
                &#9654; Submit
            </button>
        </div>
    </div>

    <!-- Info Card -->
    <div class="info-card shadow-sm mb-4">
        <div class="row">
            <div class="col-md-4">
                <div class="info-label">Employee ID</div>
                <input type="number" id="empIdInput" class="info-value border-0 p-0 bg-transparent w-100"
                       min="1" value="@(Model.EmpId ?? 1)" style="outline: none;" />
            </div>
            <div class="col-md-4">
                <div class="info-label">Week Ending</div>
                <input type="date" id="weekEndingInput" class="info-value border-0 p-0 bg-transparent w-100"
                       style="outline: none;" />
            </div>
        </div>
    </div>

    <!-- Timesheet Table -->
    <div class="timesheet-container shadow-sm">
        <div class="table-responsive">
            <table class="table table-ts align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 30%;">Work Package</th>
                        <th style="width: 20%;">Labor Grade</th>
                        <th class="text-center">Mon</th>
                        <th class="text-center">Tue</th>
                        <th class="text-center">Wed</th>
                        <th class="text-center">Thu</th>
                        <th class="text-center">Fri</th>
                        <th class="text-center">Sat</th>
                        <th class="text-center">Sun</th>
                        <th class="text-center">Total</th>
                        <th style="width: 40px;"></th>
                    </tr>
                </thead>
                <tbody id="rowsBody"></tbody>
                <tfoot>
                    <tr class="fw-bold" style="border-top: 2px solid #eef2eb;">
                        <td colspan="2" class="ps-4 py-3">Weekly Total Distribution</td>
                        <td class="text-center" id="totalMon">0.0</td>
                        <td class="text-center" id="totalTue">0.0</td>
                        <td class="text-center" id="totalWed">0.0</td>
                        <td class="text-center" id="totalThu">0.0</td>
                        <td class="text-center" id="totalFri">0.0</td>
                        <td class="text-center" id="totalSat">0.0</td>
                        <td class="text-center" id="totalSun">0.0</td>
                        <td class="text-center">
                            <span class="total-pill" id="totalAll">0.0 hrs</span>
                        </td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <!-- Submitted History -->
    <h5 class="fw-bold mt-5 mb-3 d-flex align-items-center gap-2">
        &#128336; Submitted History
    </h5>
    <div class="table-responsive">
        <table class="table">
            <thead class="text-muted" style="font-size: 0.7rem; text-transform: uppercase;">
                <tr>
                    <th>Week Period</th>
                    <th>Total Hours</th>
                    <th>Submission Date</th>
                    <th>Status</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody id="historyBody" style="font-size: 0.9rem;"></tbody>
        </table>
    </div>
</div>

<!-- Toast container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer"></div>

@section Scripts {
<script>
    const API = '@Model.ApiBaseUrl';
    const TOKEN = '@Model.JwtToken';

    async function authFetch(url, options = {}) {
        options.headers = { ...options.headers, 'Authorization': `Bearer ${TOKEN}` };
        const res = await fetch(url, options);
        if (res.status === 401) window.location.href = '/Login';
        return res;
    }

    let workPackages = [];
    let laborGrades = [];

    // ========================================================================
    // Init
    // ========================================================================

    document.addEventListener('DOMContentLoaded', async () => {
        setDefaultWeekEnding();
        await Promise.all([loadWorkPackages(), loadLaborGrades()]);
        addRow();
        loadTimesheets();
    });

    function setDefaultWeekEnding() {
        const today = new Date();
        const day = today.getDay();
        const weekEnd = new Date(today);
        weekEnd.setDate(today.getDate() - day);
        document.getElementById('weekEndingInput').value = formatDateISO(weekEnd);
    }

    // ========================================================================
    // Load dropdowns
    // ========================================================================

    async function loadWorkPackages() {
        try {
            const res = await authFetch(`${API}/api/workpackages`);
            if (!res.ok) throw new Error('Failed to load work packages');
            workPackages = await res.json();
        } catch (err) {
            showAlert('Could not load work packages: ' + err.message, 'warning');
        }
    }

    async function loadLaborGrades() {
        try {
            const res = await authFetch(`${API}/api/labor-grades`);
            if (!res.ok) throw new Error('Failed to load labor grades');
            laborGrades = await res.json();
        } catch (err) {
            showAlert('Could not load labor grades: ' + err.message, 'warning');
        }
    }

    // ========================================================================
    // Row management
    // ========================================================================

    function addRow() {
        const tbody = document.getElementById('rowsBody');
        const tr = document.createElement('tr');

        const wpOptions = workPackages.map(wp =>
            `<option value="${esc(wp.wpId)}">${esc(wp.wpId)} - ${esc(wp.wpName || '')}</option>`
        ).join('');

        const lgOptions = laborGrades.map(lg =>
            `<option value="${lg.laborGradeId}">${esc(lg.gradeCode)}</option>`
        ).join('');

        tr.innerHTML = `
            <td class="ps-3">
                <select class="form-select form-select-ts wp-select">
                    <option value="">Select...</option>
                    ${wpOptions}
                </select>
            </td>
            <td>
                <select class="form-select form-select-ts lg-select">
                    <option value="">Select...</option>
                    ${lgOptions}
                </select>
            </td>
            <td><input type="number" class="hr-input hr-mon" step="0.1" value="0" oninput="updateTotals()"></td>
            <td><input type="number" class="hr-input hr-tue" step="0.1" value="0" oninput="updateTotals()"></td>
            <td><input type="number" class="hr-input hr-wed" step="0.1" value="0" oninput="updateTotals()"></td>
            <td><input type="number" class="hr-input hr-thu" step="0.1" value="0" oninput="updateTotals()"></td>
            <td><input type="number" class="hr-input hr-fri" step="0.1" value="0" oninput="updateTotals()"></td>
            <td><input type="number" class="hr-input hr-sat" step="0.1" value="0" oninput="updateTotals()"></td>
            <td><input type="number" class="hr-input hr-sun" step="0.1" value="0" oninput="updateTotals()"></td>
            <td class="text-center fw-bold row-total">0.0</td>
            <td>
                <button class="btn btn-link btn-sm text-danger text-decoration-none"
                        onclick="removeRow(this)">&times;</button>
            </td>
        `;
        tbody.appendChild(tr);
        updateTotals();
    }

    function removeRow(btn) {
        const tbody = document.getElementById('rowsBody');
        if (tbody.rows.length <= 1) {
            showAlert('Timesheet must have at least one row.', 'warning');
            return;
        }
        btn.closest('tr').remove();
        updateTotals();
    }

    // ========================================================================
    // Totals
    // ========================================================================

    function updateTotals() {
        const days = ['mon', 'tue', 'wed', 'thu', 'fri', 'sat', 'sun'];
        let grandTotal = 0;

        days.forEach(day => {
            let daySum = 0;
            document.querySelectorAll(`.hr-${day}`).forEach(input => {
                const val = parseFloat(input.value) || 0;
                daySum += val;
                input.classList.toggle('zero', val === 0);
            });
            document.getElementById(`total${capitalize(day)}`).textContent = daySum.toFixed(1);
            grandTotal += daySum;
        });

        document.querySelectorAll('#rowsBody tr').forEach(row => {
            let rowSum = 0;
            row.querySelectorAll('.hr-input').forEach(i => rowSum += (parseFloat(i.value) || 0));
            row.querySelector('.row-total').textContent = rowSum.toFixed(1);
        });

        document.getElementById('totalAll').textContent = grandTotal.toFixed(1) + ' hrs';
    }

    // ========================================================================
    // Submit
    // ========================================================================

    async function submitTimesheet() {
        const dto = buildRequestDTO();
        if (!dto) return;

        try {
            // Step 1: Create timesheet
            const createRes = await authFetch(`${API}/api/timesheets`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dto)
            });

            if (!createRes.ok) {
                const errText = await createRes.text();
                throw new Error(errText || createRes.statusText);
            }

            const created = await createRes.json();
            const tsId = created.tsId;

            // Step 2: Submit timesheet
            const submitRes = await authFetch(`${API}/api/timesheets/${tsId}/submit`, {
                method: 'PUT'
            });

            if (!submitRes.ok) {
                const errText = await submitRes.text();
                throw new Error(errText || submitRes.statusText);
            }

            showToast('Timesheet submitted successfully!', 'success');
            resetForm();
            loadTimesheets();

        } catch (err) {
            showAlert('Submit failed: ' + err.message, 'danger');
        }
    }

    // ========================================================================
    // Build DTO
    // ========================================================================

    function buildRequestDTO() {
        const empId = parseInt(document.getElementById('empIdInput').value);
        const weekEnding = document.getElementById('weekEndingInput').value;

        if (!empId || empId <= 0) {
            showAlert('Please enter a valid Employee ID.', 'warning');
            return null;
        }
        if (!weekEnding) {
            showAlert('Please select a Week Ending date.', 'warning');
            return null;
        }

        const rows = [];
        let valid = true;

        document.querySelectorAll('#rowsBody tr').forEach((tr, idx) => {
            const wpId = tr.querySelector('.wp-select').value;
            const lgId = tr.querySelector('.lg-select').value;

            if (!wpId) {
                showAlert(`Row ${idx + 1}: Please select a Work Package.`, 'warning');
                valid = false;
                return;
            }
            if (!lgId) {
                showAlert(`Row ${idx + 1}: Please select a Labor Grade.`, 'warning');
                valid = false;
                return;
            }

            rows.push({
                wpId: wpId,
                laborGradeId: parseInt(lgId),
                monday:    parseHours(tr.querySelector('.hr-mon').value),
                tuesday:   parseHours(tr.querySelector('.hr-tue').value),
                wednesday: parseHours(tr.querySelector('.hr-wed').value),
                thursday:  parseHours(tr.querySelector('.hr-thu').value),
                friday:    parseHours(tr.querySelector('.hr-fri').value),
                saturday:  parseHours(tr.querySelector('.hr-sat').value),
                sunday:    parseHours(tr.querySelector('.hr-sun').value)
            });
        });

        if (!valid) return null;
        return { empId, weekEnding, rows };
    }

    // ========================================================================
    // Reset form
    // ========================================================================

    function resetForm() {
        document.getElementById('rowsBody').innerHTML = '';
        addRow();
    }

    // ========================================================================
    // Load submitted history
    // ========================================================================

    async function loadTimesheets() {
        const empId = document.getElementById('empIdInput').value;
        if (!empId) return;

        const historyBody = document.getElementById('historyBody');
        historyBody.innerHTML = '<tr><td colspan="5" class="text-muted">Loading...</td></tr>';

        try {
            const res = await authFetch(`${API}/api/timesheets?empId=${empId}`);
            if (!res.ok) throw new Error(await res.text());
            const list = await res.json();

            if (list.length === 0) {
                historyBody.innerHTML = '<tr><td colspan="5" class="text-muted">No timesheets found.</td></tr>';
                return;
            }

            historyBody.innerHTML = list.map(ts => {
                const totalHours = (ts.rows || []).reduce((sum, r) =>
                    sum + (r.monday||0) + (r.tuesday||0) + (r.wednesday||0)
                        + (r.thursday||0) + (r.friday||0) + (r.saturday||0) + (r.sunday||0), 0);

                return `
                    <tr>
                        <td>${esc(ts.weekEnding || '')}</td>
                        <td>${totalHours.toFixed(1)}</td>
                        <td>${esc(ts.weekEnding || '')}</td>
                        <td>${renderStatusBadge(ts.status || 'DRAFT')}</td>
                        <td class="text-end">
                            <a href="#" class="text-muted text-decoration-none"
                               onclick="toggleDetail(${ts.tsId}); return false;">View Details</a>
                        </td>
                    </tr>
                    <tr id="detail-${ts.tsId}" style="display:none;">
                        <td colspan="5" class="p-0">${renderTimesheetDetail(ts)}</td>
                    </tr>
                `;
            }).join('');

        } catch (err) {
            historyBody.innerHTML = `<tr><td colspan="5" class="text-danger">Error: ${esc(err.message)}</td></tr>`;
        }
    }

    function renderTimesheetDetail(ts) {
        if (!ts.rows || ts.rows.length === 0) return '<div class="p-3 text-muted">No rows.</div>';

        const dayFields = ['monday','tuesday','wednesday','thursday','friday','saturday','sunday'];
        const dayHeaders = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

        const rowsHtml = ts.rows.map(r => {
            const dayValues = dayFields.map(f => `<td class="text-center">${r[f] != null ? r[f] : '—'}</td>`).join('');
            const rowTotal = dayFields.reduce((s, f) => s + (r[f] || 0), 0);
            return `
                <tr>
                    <td>${esc(r.wpId || '')}${r.wpName ? ' - ' + esc(r.wpName) : ''}</td>
                    <td>${esc(r.laborGradeCode || '')}</td>
                    ${dayValues}
                    <td class="text-center fw-bold">${rowTotal.toFixed(1)}</td>
                </tr>`;
        }).join('');

        return `
            <div style="background-color: #f5f7f0; border-top: 1px solid #e0e8e0;">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr style="font-size: 0.7rem; text-transform: uppercase; color: #7c8b7c;">
                            <th>Work Package</th><th>Grade</th>
                            ${dayHeaders.map(d => `<th class="text-center">${d}</th>`).join('')}
                            <th class="text-center">Total</th>
                        </tr>
                    </thead>
                    <tbody>${rowsHtml}</tbody>
                </table>
            </div>`;
    }

    function toggleDetail(tsId) {
        const row = document.getElementById(`detail-${tsId}`);
        if (row) row.style.display = row.style.display === 'none' ? '' : 'none';
    }

    function renderStatusBadge(status) {
        if (status === 'APPROVED') return '<span class="badge-approved">APPROVED</span>';
        if (status === 'SUBMITTED') return '<span class="badge-processing">PROCESSING</span>';
        if (status === 'RETURNED') return '<span class="badge-returned">RETURNED</span>';
        return '<span class="badge-draft">DRAFT</span>';
    }

    // ========================================================================
    // Helpers
    // ========================================================================

    function showAlert(msg, type) {
        document.getElementById('alertArea').innerHTML = `
            <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                ${esc(msg)}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>`;
    }

    function showToast(msg, type) {
        const c = document.getElementById('toastContainer');
        const t = document.createElement('div');
        t.className = `toast align-items-center text-bg-${type} border-0 show`;
        t.setAttribute('role', 'alert');
        t.innerHTML = `
            <div class="d-flex">
                <div class="toast-body">${esc(msg)}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>`;
        c.appendChild(t);
        setTimeout(() => t.remove(), 4000);
    }

    function esc(str) {
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }

    function capitalize(s) { return s.charAt(0).toUpperCase() + s.slice(1); }
    function formatDateISO(d) { return d.toISOString().split('T')[0]; }
    function parseHours(val) { const n = parseFloat(val); return isNaN(n) ? 0 : Math.round(n * 10) / 10; }
</script>
}