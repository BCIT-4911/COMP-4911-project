@inject IConfiguration Config
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - frontend</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/frontend.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">frontend</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @{
                        var role = Context.Session.GetString("SystemRole") ?? "";
                        var empId = Context.Session.GetString("EmpId") ?? "";
                        var jwt = Context.Session.GetString("JWT") ?? "";
                        var apiBaseUrl = Config["ApiBaseUrl"] ?? "";
                        var isLoggedIn = !string.IsNullOrEmpty(role) || !string.IsNullOrEmpty(Context.Session.GetString("JWT"));
                    }
                    <ul class="navbar-nav flex-grow-1">
                        @if (isLoggedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Timesheets/Index">Timesheet</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-page="/Projects">Projects</a>
                            </li>
                            <li class="nav-item" id="approverNavItem" style="display:none;">
                                <a class="nav-link text-dark" asp-page="/Approver/Index">Approver Dashboard</a>
                            </li>
                            @if (role == "OPERATIONS_MANAGER")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-page="/EarnedValue/Index">Earned Value</a>
                                </li>
                            }
                            @if (role == "HR")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-page="/Employees">Employees</a>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-page="/Login">Login</a>
                            </li>
                        }
                    </ul>
                    @if (isLoggedIn)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <span class="nav-link text-muted">Emp #@empId</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Login" asp-page-handler="Logout">Logout</a>
                            </li>
                        </ul>

                        <script>
                            (function () {
                                const token = '@jwt';
                                const apiBaseUrl = '@apiBaseUrl';
                                if (!token || !apiBaseUrl) return;

                                const cached = sessionStorage.getItem('canAccessApprover');
                                if (cached === 'true') {
                                    document.getElementById('approverNavItem').style.display = '';
                                    return;
                                }
                                if (cached === 'false') return;

                                fetch(`${apiBaseUrl}/api/auth/can-access-approver-dashboard`, {
                                    headers: { 'Authorization': `Bearer ${token}` }
                                })
                                    .then(r => r.ok ? r.json() : null)
                                    .then(data => {
                                        const allowed = data && data.allowed;
                                        sessionStorage.setItem('canAccessApprover', String(allowed));
                                        if (allowed) {
                                            document.getElementById('approverNavItem').style.display = '';
                                        }
                                    })
                                    .catch(() => {});
                            })();
                        </script>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - frontend - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>