@section Scripts {
<script>
    const API = '@Model.ApiBaseUrl';

    // ---- Load Employees ----
    async function loadEmployees() {
        try {
            const res = await fetch(`${API}/api/employees`);
            if (!res.ok) throw new Error('Failed to load employees');
            const employees = await res.json();
            renderTable(employees);
        } catch (err) {
            document.getElementById('employeesBody').innerHTML =
                `<tr><td colspan="6" class="error-cell">Error loading employees: ${err.message}</td></tr>`;
        }
    }

    function renderTable(employees) {
        const tbody = document.getElementById('employeesBody');
        if (employees.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="empty-cell">No employees found. Click "New Employee" to create one.</td></tr>';
            return;
        }
        tbody.innerHTML = employees.map(e => `
            <tr>
                <td><code>${esc(e.empId)}</code></td>
                <td class="name-cell">${esc(e.empFirstName || '')}</td>
                <td class="name-cell">${esc(e.empLastName || '')}</td>
                <td><span class="badge ${e.systemRole ? 'badge-type' : ''}">${esc(e.systemRole || 'N/A')}</span></td>
                <td>${e.expectedWeeklyHours != null ? parseFloat(e.expectedWeeklyHours).toFixed(1) : '0.0'}</td>
                <td class="actions-cell">
                    <button class="btn-action btn-edit" onclick='openEditModal(${JSON.stringify(e)})' title="Edit">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    </button>
                    <button class="btn-action btn-delete" onclick="deleteEmployee('${esc(e.empId)}')" title="Delete">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                    </button>
                </td>
            </tr>
        `).join('');
    }

    // ---- Create ----
    function openCreateModal() {
        document.getElementById('editMode').value = 'false';
        document.getElementById('modalTitle').textContent = 'New Employee';
        document.getElementById('submitBtn').textContent = 'Create Employee';
        document.getElementById('employeeForm').reset();
        document.getElementById('empId').value = '';
        document.getElementById('employeeModal').classList.add('active');
    }

    // ---- Edit ----
    function openEditModal(e) {
        document.getElementById('editMode').value = 'true';
        document.getElementById('empId').value = e.empId;
        document.getElementById('modalTitle').textContent = 'Edit Employee';
        document.getElementById('submitBtn').textContent = 'Save Changes';
        
        document.getElementById('empFirstName').value = e.empFirstName || '';
        document.getElementById('empLastName').value = e.empLastName || '';
        document.getElementById('systemRole').value = e.systemRole || '';
        document.getElementById('expectedWeeklyHours').value = e.expectedWeeklyHours != null ? e.expectedWeeklyHours : '';
        
        document.getElementById('employeeModal').classList.add('active');
    }

    function closeModal() {
        document.getElementById('employeeModal').classList.remove('active');
    }

    // ---- Submit (Create or Update) ----
    async function handleSubmit(e) {
        e.preventDefault();
        const isEdit = document.getElementById('editMode').value === 'true';
        const id = document.getElementById('empId').value;

        const body = {
            empFirstName: document.getElementById('empFirstName').value,
            empLastName: document.getElementById('empLastName').value,
            systemRole: document.getElementById('systemRole').value,
            expectedWeeklyHours: parseFloat(document.getElementById('expectedWeeklyHours').value) || 0
        };

        try {
            const url = isEdit ? `${API}/api/employees/${encodeURIComponent(id)}` : `${API}/api/employees`;
            const res = await fetch(url, {
                method: isEdit ? 'PUT' : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            if (!res.ok) {
                const text = await res.text();
                throw new Error(text || res.statusText);
            }
            closeModal();
            showToast(isEdit ? 'Employee updated!' : 'Employee created!', 'success');
            loadEmployees();
        } catch (err) {
            showToast('Error: ' + err.message, 'error');
        }
    }

    // ---- Delete ----
    async function deleteEmployee(id) {
        if (!confirm(`Delete employee ID "${id}"? This cannot be undone.`)) return;
        try {
            const res = await fetch(`${API}/api/employees/${encodeURIComponent(id)}`, { method: 'DELETE' });
            if (!res.ok) throw new Error(await res.text());
            showToast('Employee deleted!', 'success');
            loadEmployees();
        } catch (err) {
            showToast('Error: ' + err.message, 'error');
        }
    }

    // ---- Helpers ----
    function esc(str) {
        if (str == null) return '';
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }
    function showToast(msg, type) {
        const c = document.getElementById('toastContainer');
        const t = document.createElement('div');
        t.className = `toast toast-${type}`;
        t.textContent = msg;
        c.appendChild(t);
        setTimeout(() => { t.classList.add('fade-out'); setTimeout(() => t.remove(), 300); }, 3000);
    }

    // ---- Init ----
    document.addEventListener('DOMContentLoaded', loadEmployees);
</script>
}
